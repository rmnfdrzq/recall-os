# Django Configurations
DEBUG=True
SECRET_KEY=django-insecure-recallos-development-secret-key-change-this
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configurations
DATABASE_URL=postgres://recallos_user:recallos_secure_pass@localhost:5432/recallos
DB_NAME=recallos
DB_USER=recallos_user
DB_PASSWORD=recallos_secure_pass
DB_HOST=localhost
DB_PORT=5432

# Redis & Celery Configurations
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# AI & Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma4:e2b
OLLAMA_EMBED_MODEL=nomic-embed-text-v2-moe
# Alternative embedding model: all-minilm

# OCR Configuration
OCR_ENGINE=easyocr  # easyocr (pytesseract is disabled and avoided)
